{
  "name": "medchain",
  "version": "0.2.0",
  "type": "module",
  "description": "MedChain - La Seavyong",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "medchain": "dist/bin/medchain.cjs"
  },
  "files": [
    "dist",
    "dashboard",
    "DOCS.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check ../medchain/server/medchain",
    "lint:fix": "biome check --fix ../medchain/server/medchain",
    "format": "biome format --write ../medchain/server/medchain",
    "prepublishOnly": "np m run build && npm run test"
  },
  "keywords": [
    "blockchain",
    "private-blockchain",
    "permissioned-blockchain",
    "consortium-blockchain",
    "enterprise-blockchain",
    "distributed-ledger",
    "dlt",
    "ledger",
    "hyperledger-alternative",
    "blockchain-framework",
    "blockchain-platform",
    "smart-contracts",
    "raft-consensus",
    "sqlite",
    "sql-blockchain",
    "block-explorer",
    "embeddable-blockchain",
    "nodejs-blockchain",
    "typescript-blockchain",
    "web3",
    "supply-chain",
    "audit-trail",
    "immutable-ledger",
    "on-chain-governance",
    "p2p",
    "zero-config"
  ],
  "author": "Chainscore Labs <hello@chainscore.finance> (https://chainscorelabs.com)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@noble/ciphers": "^2.1.1",
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.1",
    "better-sqlite3": "^11.8.1",
    "commander": "^13.1.0",
    "eventemitter3": "^5.0.1",
    "hono": "^4.7.4",
    "miniledger": "^0.2.0",
    "pino": "^9.6.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^3.0.5",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "directories": {
    "example": "examples",
    "test": "tests"
  }
}
